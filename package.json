{
  "name": "kennice-tours-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --disable-source-maps",
    "dev:clean": "node -e \"require('fs').rmSync('.next', { recursive: true, force: true })\" && next dev --disable-source-maps",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "dev:turbo": "next dev --turbo --disable-source-maps"
  },
  "dependencies": {
    "next": "^15.2.8",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@types/node": "22.13.10",
    "@types/react": "19.0.10",
    "@types/react-dom": "19.0.4",
    "typescript": "5.8.2"
  }
}
